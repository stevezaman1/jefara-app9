rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOfCompany(companyId) {
      return isAuthenticated() && (
        getUserData().companyId == companyId ||
        (request.resource != null && request.resource.data.companyId == companyId)
      );
    }

    // User collection rules
    match /users/{uid} {
      allow read, write: if isAuthenticated() && (request.auth.uid == uid || getUserData().role == "Owner");
    }

    // Demo leads collection rules
    match /demo_leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated() && getUserData().role == "Owner";
    }

    // Company collection rules
    match /companies/{companyId} {
      allow create: if isAuthenticated();
      allow read, write: if isAuthenticated() && isMemberOfCompany(companyId);

      // Sub-collections nested under companies
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && isMemberOfCompany(companyId);
      }
    }
  }
}
